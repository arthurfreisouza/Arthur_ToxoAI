# Copy this file to .env and fill in the values before starting the server.
# Never commit .env to git.

# HuggingFace API token (required for the AI chat endpoint)
HF_API_TOKEN=hf_your_token_here

# JWT signing secret — use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# ── Email verification (Resend) ────────────────────────────────────────────
# Resend API key — create one at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# "From" address used for verification emails. Must be a verified domain/sender in Resend.
EMAIL_FROM=ToxoAI <onboarding@resend.dev>

# How long a verification link stays valid
VERIFICATION_TOKEN_EXPIRE_HOURS=24

# Public URL of this API (used to build the verification link). In production
# this is the domain nginx proxies /api/ on, e.g. https://mychatbotproject.uk
BACKEND_URL=http://localhost:8000

# Where users are sent after clicking the verification link
FRONTEND_URL=http://localhost:8080
