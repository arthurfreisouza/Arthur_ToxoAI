# --- Core ---
ENVIRONMENT=development
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
VERIFICATION_TOKEN_EXPIRE_HOURS=24

# --- Database ---
# SQLite (default for local dev):
DATABASE_URL=sqlite:///./users.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg://iatoxo:CHANGE_ME@localhost:5432/iatoxo

# --- CORS ---
# Comma-separated list of allowed origins. Leave empty (or omit) to allow all (*).
# In production, leave empty when the frontend is served from the same origin behind nginx.
CORS_ORIGINS=

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=IA-Toxo

# --- Frontend ---
# Public URL used to build the verification link in emails
FRONTEND_URL=https://yourdomain.com
