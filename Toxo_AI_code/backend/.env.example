# --- Core ---
ENVIRONMENT=development
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
VERIFICATION_TOKEN_EXPIRE_HOURS=24

# --- Database (PostgreSQL via psycopg 3) ---
DATABASE_URL=postgresql+psycopg://iatoxo:CHANGE_ME@localhost:5432/iatoxo

# --- CORS (JSON list). In production set this to your real origin(s). ---
# Leave empty [] when frontend and API share an origin behind nginx.
CORS_ORIGINS=[]

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=IA-Toxo

# --- Frontend ---
# Public URL of the frontend (used to build verification links in emails)
FRONTEND_URL=https://yourdomain.com
